<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:orientation="vertical">

    <ImageButton
        android:id="@+id/backBtn"
        android:layout_width="47dp"
        android:layout_height="43dp"
        android:layout_marginStart="10dp"
        android:backgroundTint="@color/transparent"
        android:scaleType="fitXY"
        android:scaleX="-1"
        android:src="@drawable/ic_chevron_black" />

    <RelativeLayout
        android:layout_width="350dp"
        android:layout_height="450dp"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:background="@drawable/default_postit"
        android:paddingTop="55dp"
        android:paddingStart="17dp"
        android:paddingEnd="17dp"
        android:paddingBottom="17dp">

        <TextView
            android:id="@+id/text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="89dp"
            android:ellipsize="end"
            android:fontFamily="@font/yeongdeoksea"
            android:maxLines="4"
            android:text="To. "
            android:textColor="@color/black"
            android:textSize="24dp" />

        <TextView
            android:id="@+id/to"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/text"
            android:layout_alignParentTop="true"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="89dp"
            android:ellipsize="end"
            android:fontFamily="@font/yeongdeoksea"
            android:maxLines="4"
            android:text="하연"
            android:textColor="@color/black"
            android:textSize="24dp" />

        <TextView
            android:id="@+id/text2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/to"
            android:layout_alignParentTop="true"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="89dp"
            android:ellipsize="end"
            android:fontFamily="@font/yeongdeoksea"
            android:maxLines="4"
            android:text="에게"
            android:textColor="@color/black"
            android:textSize="24dp" />


        <TextView
            android:id="@+id/message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/to"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="25dp"
            android:ellipsize="end"
            android:fontFamily="@font/yeongdeoksea"
            android:lineSpacingExtra="5px"
            android:maxLines="4"
            android:text="하연 ~~ 오늘 중간고사지?\n엄마가 아침밥도 못 챙겨주고 나왔네..\n떨지 말고 찬찬히 풀고 나오세요.\n오늘도 사랑해 우리 딸 ❤️"
            android:textColor="@color/black"
            android:textSize="22dp" />

        <TextView
            android:id="@+id/date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_above="@id/from"
            android:layout_gravity="center_horizontal"
            android:layout_marginRight="15dp"
            android:layout_marginBottom="5dp"
            android:ellipsize="end"
            android:fontFamily="@font/yeongdeoksea"
            android:maxLines="4"
            android:text="2024년 5월 10일"
            android:textColor="@color/black"
            android:textSize="22dp" />

        <TextView
            android:id="@+id/text3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_toLeftOf="@id/from"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"
            android:ellipsize="end"
            android:fontFamily="@font/yeongdeoksea"
            android:maxLines="4"
            android:text="From. "
            android:textColor="@color/black"
            android:textSize="22dp" />

        <TextView
            android:id="@+id/from"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"
            android:layout_marginRight="15dp"
            android:ellipsize="end"
            android:fontFamily="@font/yeongdeoksea"
            android:maxLines="4"
            android:text="엄마"
            android:textColor="@color/black"
            android:textSize="22dp" />
    </RelativeLayout>

    <Button
        android:id="@+id/okBtn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginTop="160dp"
        android:background="@drawable/rounded_button"
        android:fontFamily="@font/pretendardsemibold"
        android:text="답장 쓰러 가기"
        android:textColor="@color/white"
        android:textSize="20dp" />
</LinearLayout>