<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/backBtn"
            android:layout_width="47dp"
            android:layout_height="43dp"
            android:backgroundTint="@color/transparent"
            android:src="@drawable/ic_chevron_black"
            android:layout_marginLeft="8dp"
            android:layout_gravity="center"
            android:layout_marginRight="8dp"
            android:rotation="180"
            android:scaleType="centerCrop"/>

        <View
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/pagename"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="방명록 작성"
            android:layout_gravity="center"
            android:textSize="23dp"
            android:fontFamily="@font/pretendardbold"
            android:textColor="@color/black" />

        <View
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/hamBtn"
            android:layout_width="25dp"
            android:layout_height="38dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_threedot"
            android:backgroundTint="@color/transparent"
            android:layout_marginRight="20dp"
            android:scaleType="centerCrop"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:orientation="vertical" >

        <TextView
            android:id="@+id/ment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="소소한 일상을\n방명록으로 남겨보아요✍🏻"
            android:fontFamily="@font/pretendardsemibold"
            android:textSize="26dp"
            android:textColor="@color/black"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내용"
            android:fontFamily="@font/pretendardbold"
            android:textSize="22dp"
            android:textColor="@color/blue"
            android:layout_marginTop="40dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/contentEdit"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="@drawable/rounded_textbox"
                android:layout_marginTop="15dp"
                android:padding="13dp"
                android:hint="입력..."
                android:textColorHint="@color/hintgray"
                android:fontFamily="@font/pretendardsemibold"
                android:gravity="start"
                android:textSize="17dp"/>

            <TextView
                android:id="@+id/count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/text"
                android:layout_alignBottom="@id/contentEdit"
                android:layout_marginBottom="15dp"
                android:text="0"
                android:textSize="15dp"
                android:textColor="@color/gray"
                android:fontFamily="@font/pretendardregular"/>

            <TextView
                android:id="@+id/text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignBottom="@id/contentEdit"
                android:layout_alignEnd="@id/contentEdit"
                android:layout_marginBottom="15dp"
                android:layout_marginEnd="15dp"
                android:text="/100자"
                android:textSize="15dp"
                android:textColor="@color/gray"
                android:fontFamily="@font/pretendardregular"/>

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>

        <Button
            android:id="@+id/okBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/rounded_button"
            android:text="올리기"
            android:textSize="20dp"
            android:textColor="@color/white"
            android:fontFamily="@font/pretendardsemibold"
            android:layout_marginBottom="20dp" />

    </LinearLayout>

</LinearLayout>