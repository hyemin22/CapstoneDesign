<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/wishLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="5dp"
    android:layout_marginTop="10dp"
    android:background="@drawable/rounded_textbox">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp">

        <TextView
            android:id="@+id/emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="❤️"
            android:textColor="@color/black"
            android:textSize="40dp" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/emoji"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:fontFamily="@font/pretendardbold"
            android:maxLines="1"
            android:text="가족과 산책하기"
            android:textColor="@color/black"
            android:textSize="20dp" />

        <TextView
            android:id="@+id/cycle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/emoji"
            android:layout_below="@+id/title"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="25dp"
            android:ellipsize="end"
            android:fontFamily="@font/pretendardmedium"
            android:maxLines="1"
            android:text="주간 목표"
            android:textColor="@color/black"
            android:textSize="17dp" />

        <ImageButton
            android:id="@+id/imgBtnArrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="10dp"
            android:background="@color/transparent"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/ic_chevron_black" />

        <TextView
            android:id="@+id/text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/cycle"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/pretendardregular"
            android:gravity="center"
            android:text="이번주 미션 진행률"
            android:textColor="@color/black"
            android:textSize="18dp" />

        <TextView
            android:id="@+id/percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/cycle"
            android:layout_toStartOf="@id/text2"
            android:layout_marginStart="190dp"
            android:fontFamily="@font/pretendardsemibold"
            android:text="50"
            android:textSize="16dp"
            android:textColor="@color/blue"/>

        <TextView
            android:id="@+id/text2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/cycle"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="15dp"
            android:fontFamily="@font/pretendardsemibold"
            android:text="%"
            android:textSize="16dp"
            android:textColor="@color/blue"/>

        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="325dp"
            android:layout_height="15dp"
            android:layout_below="@id/text"
            android:layout_marginTop="12dp"
            android:layout_centerHorizontal="true"
            style="?android:attr/progressBarStyleHorizontal"
            android:progress="10"
            android:max="100"
            android:progressDrawable="@drawable/progressbar"/>

        <TextView
            android:id="@+id/text3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/progress"
            android:layout_marginTop="10dp"
            android:layout_marginStart="10dp"
            android:text="오늘 기준"
            android:textSize="16dp"
            android:fontFamily="@font/pretendardregular"
            android:textColor="@color/gray"/>

        <TextView
            android:id="@+id/text4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/progress"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="15dp"
            android:text="실천 목표"
            android:textSize="16dp"
            android:fontFamily="@font/pretendardregular"
            android:textColor="@color/gray"/>

        <TextView
            android:id="@+id/count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/text3"
            android:layout_marginStart="10dp"
            android:text="2"
            android:textSize="18dp"
            android:fontFamily="@font/pretendardsemibold"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/text5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/text3"
            android:layout_toEndOf="@id/count"
            android:text="회"
            android:textSize="18dp"
            android:fontFamily="@font/pretendardsemibold"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/goal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/text4"
            android:layout_toStartOf="@id/text6"
            android:text="4"
            android:textSize="18dp"
            android:fontFamily="@font/pretendardsemibold"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/text6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:layout_below="@id/text4"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="15dp"
            android:text="회"
            android:textSize="18dp"
            android:fontFamily="@font/pretendardsemibold"
            android:textColor="@color/black"/>

    </RelativeLayout>
</RelativeLayout>