<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/wishLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="5dp"
    android:background="@drawable/rounded_textbox">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp">

        <TextView
            android:id="@+id/emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:text="❤️"
            android:textColor="@color/black"
            android:textSize="35dp" />

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginTop="8dp"
            android:layout_toEndOf="@+id/emoji"
            android:ellipsize="end"
            android:fontFamily="@font/pretendardbold"
            android:maxLines="1"
            android:text="가족과 산책하기"
            android:textColor="@color/black"
            android:textSize="20dp" />

        <TextView
            android:id="@+id/cycle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/title"
            android:layout_marginStart="5dp"
            android:layout_marginBottom="25dp"
            android:layout_toEndOf="@+id/emoji"
            android:ellipsize="end"
            android:fontFamily="@font/pretendardmedium"
            android:maxLines="1"
            android:text="주간 목표"
            android:textColor="@color/black"
            android:textSize="17dp" />

        <ImageButton
            android:id="@+id/imgBtnArrow"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="5dp"
            android:background="@color/transparent"
            android:scaleType="fitXY"
            app:srcCompat="@drawable/ic_chevron_black" />

        <RelativeLayout
            android:id="@+id/progressView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/cycle"
            android:visibility="gone">

            <TextView
                android:id="@+id/text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/pretendardregular"
                android:gravity="center"
                android:text="이번주 미션 진행률"
                android:textColor="@color/black"
                android:textSize="18dp" />

            <TextView
                android:id="@+id/percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="190dp"
                android:layout_toStartOf="@id/text2"
                android:fontFamily="@font/pretendardsemibold"
                android:text="50"
                android:textColor="@color/blue"
                android:textSize="16dp" />

            <TextView
                android:id="@+id/text2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="15dp"
                android:fontFamily="@font/pretendardsemibold"
                android:text="%"
                android:textColor="@color/blue"
                android:textSize="16dp" />

            <ProgressBar
                android:id="@+id/progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="325dp"
                android:layout_height="15dp"
                android:layout_below="@id/text"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="12dp"
                android:max="1000"
                android:progress="500"
                android:progressDrawable="@drawable/progressbar" />

            <TextView
                android:id="@+id/text3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/progress"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/pretendardregular"
                android:text="오늘 기준"
                android:textColor="@color/gray"
                android:textSize="16dp" />

            <TextView
                android:id="@+id/text4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/progress"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="15dp"
                android:fontFamily="@font/pretendardregular"
                android:text="실천 목표"
                android:textColor="@color/gray"
                android:textSize="16dp" />

            <TextView
                android:id="@+id/count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/text3"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/pretendardsemibold"
                android:text="2"
                android:textColor="@color/black"
                android:textSize="18dp" />

            <TextView
                android:id="@+id/text5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/text3"
                android:layout_toEndOf="@id/count"
                android:fontFamily="@font/pretendardsemibold"
                android:text="회"
                android:textColor="@color/black"
                android:textSize="18dp" />

            <TextView
                android:id="@+id/goal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/text4"
                android:layout_toStartOf="@id/text6"
                android:fontFamily="@font/pretendardsemibold"
                android:text="4"
                android:textColor="@color/black"
                android:textSize="18dp" />

            <TextView
                android:id="@+id/text6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/text4"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="15dp"
                android:layout_marginBottom="5dp"
                android:fontFamily="@font/pretendardsemibold"
                android:text="회"
                android:textColor="@color/black"
                android:textSize="18dp" />

        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/emptyCycleView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="15dp"
            android:layout_marginStart="20dp"
            android:layout_below="@id/cycle"
            android:visibility="visible">

            <TextView
                android:id="@+id/text7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="미션을 클릭해"
                android:fontFamily="@font/pretendardmedium"
                android:textSize="17dp"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/text8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toRightOf="@id/text7"
                android:text=" 미션 주기"
                android:fontFamily="@font/pretendardbold"
                android:textSize="17dp"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toRightOf="@id/text8"
                android:text="를 설정해주세요."
                android:fontFamily="@font/pretendardmedium"
                android:textSize="17dp"
                android:textColor="@color/black" />

        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>