<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".activity.DiaryCreateActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="30dp"
        app:layout_constraintBottom_toTopOf="@id/okBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/backBtn"
                    android:layout_width="40dp"
                    android:layout_height="30dp"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/pretendardregular"
                    android:gravity="center"
                    android:text="취소"
                    android:textColor="@color/black"
                    android:textSize="18dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_centerInParent="true" >


                    <EditText
                        android:id="@+id/editTextDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="5dp"
                        android:layout_marginLeft="5dp"
                        android:gravity="center"
                        android:background="@color/transparent"
                        android:ems="10"
                        android:focusable="false"
                        android:fontFamily="@font/pretendardsemibold"
                        android:hint="YYYY. MM. DD"
                        android:textColorHint="@color/black"
                        android:inputType="date"
                        android:textColor="@color/black"
                        android:textSize="17dp" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/editDate"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_gravity="center"
                    android:layout_marginRight="20dp"
                    android:src="@drawable/ic_cal" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="7dp"
                android:layout_gravity="center"
                android:background="#EFEFEF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <EditText
                    android:id="@+id/titleEdit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@color/transparent"
                    android:fontFamily="@font/pretendardsemibold"
                    android:hint="제목"
                    android:maxLines="1"
                    android:textColor="@color/black"
                    android:textColorHint="@color/hintgray"
                    android:textSize="28dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EFEFEF"
                    android:layout_gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="앨범 선택하기"
                    android:textColor="@color/black"
                    android:textSize="20dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:layout_toStartOf="@id/albumPicker"
                        android:fontFamily="@font/pretendardbold"
                        android:text="  "
                        android:textColor="@color/black"
                        android:textSize="18dp" />

                    <Spinner
                        android:id="@+id/albumPicker"
                        style="@style/Widget.AppCompat.Spinner"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:paddingStart="10dp"
                        android:background="@drawable/rounded_textbox2"
                        android:fontFamily="@font/pretendardbold"
                        android:gravity="center"
                        android:spinnerMode="dropdown"
                        android:textColor="@color/black"
                        android:textSize="18dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:fontFamily="@font/pretendardbold"
                        android:text="▼   "
                        android:layout_gravity="end|center_vertical"
                        android:textColor="@color/gray1"
                        android:textSize="18dp" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="일기 남기기"
                    android:textColor="@color/black"
                    android:textSize="20dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/rounded_textbox2"
                    android:orientation="vertical">

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <EditText
                            android:id="@+id/content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="10dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="@font/pretendardregular"
                            android:hint=" 가족과 나눈 이야기를 자유롭게 작성해주세요."
                            android:textColor="@color/black"
                            android:textColorHint="@color/hintgray"
                            android:textSize="18dp" />

                    </ScrollView>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="위치 추가"
                    android:textColor="@color/black"
                    android:textSize="20dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_gravity="center">

                    <EditText
                        android:id="@+id/editPlace"
                        style="@style/Widget.AppCompat.Spinner"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:inputType="text"
                        android:hint="추억을 나눈 장소를 검색해 보세요"
                        android:paddingStart="10dp"
                        android:textColorHint="@color/hintgray"
                        android:background="@drawable/rounded_textbox2"
                        android:fontFamily="@font/pretendardregular"
                        android:spinnerMode="dropdown"
                        android:textColor="@color/black"
                        android:textSize="18dp" />

                    <TextView
                        android:id="@+id/search"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:fontFamily="@font/pretendardsemibold"
                        android:text="검색   "
                        android:layout_gravity="end|center_vertical"
                        android:textColor="@color/black"
                        android:textSize="15dp" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="사진 추가하기"
                    android:textColor="@color/black"
                    android:textSize="20dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <HorizontalScrollView
                        android:layout_width="wrap_content"
                        android:layout_height="250dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card1"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img1"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/ic_addphoto"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card2"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img2"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/ic_addphoto"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card3"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img3"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/ic_addphoto"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card4"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img4"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/ic_addphoto"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card5"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img5"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/ic_addphoto"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card6"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img6"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/ic_addphoto"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card7"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img7"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/ic_addphoto"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card8"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img8"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/ic_addphoto"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card9"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img9"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/ic_addphoto"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card10"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img10"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/ic_addphoto"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>


            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/okBtn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/rounded_button"
        android:fontFamily="@font/pretendardsemibold"
        android:text="저장하기"
        android:textColor="@color/white"
        android:textSize="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>