<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageButton
        android:layout_width="47dp"
        android:layout_height="43dp"
        android:backgroundTint="@color/transparent"
        android:scaleType="fitXY"
        android:scaleX="-1"
        android:src="@drawable/ic_chevron_black"
        android:layout_marginTop="25dp"
        android:layout_marginLeft="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:orientation="vertical" >

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="어떤 앨범을\n만드시나요?"
        android:fontFamily="@font/pretendardsemibold"
        android:textSize="26dp"
        android:textColor="@color/black"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="제목 *"
            android:fontFamily="@font/pretendardbold"
            android:textSize="22dp"
            android:textColor="@color/blue"
            android:layout_marginTop="40dp" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/rounded_textbox"
            android:layout_marginTop="5dp"
            android:hint="   입력..."/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="표지 색상 *"
            android:fontFamily="@font/pretendardbold"
            android:textSize="22dp"
            android:textColor="@color/blue"
            android:layout_marginTop="40dp" />

        <LinearLayout
            android:layout_width="330dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal" >

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="5dp"
                android:background="@drawable/color_button"
                android:backgroundTint="#FFEFCA"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="5dp"
                android:background="@drawable/color_button"
                android:backgroundTint="#FFCBBC"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="5dp"
                android:background="@drawable/color_button"
                android:backgroundTint="#BFD7F8"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="5dp"
                android:background="@drawable/color_button"
                android:backgroundTint="#D9BCFF"/>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="5dp"
                android:background="@drawable/color_button"
                android:backgroundTint="#D9D9D9"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사진 추가 (최대 3장)"
            android:fontFamily="@font/pretendardbold"
            android:textSize="22dp"
            android:textColor="@color/blue"
            android:layout_marginTop="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사진은 앨범 표지에 랜덤으로 배치됩니다."
            android:fontFamily="@font/pretendardregular"
            android:textSize="17dp"
            android:textColor="@color/gray"
            android:layout_marginTop="5dp" />

        <ImageButton
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_image_add"
            android:backgroundTint="@color/transparent"
            android:layout_marginTop="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이모지 추가 (최대 1개)"
            android:fontFamily="@font/pretendardbold"
            android:textSize="22dp"
            android:textColor="@color/blue"
            android:layout_marginTop="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이모지는 표지 여백에 랜덤으로 배치됩니다."
            android:fontFamily="@font/pretendardregular"
            android:textSize="17dp"
            android:textColor="@color/gray"
            android:layout_marginTop="5dp" />

        <GridLayout
            android:id="@+id/gridIcon"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:columnCount="4"
            android:rowCount="2"
            android:orientation="horizontal"
            android:layout_marginTop="10dp" >

            <ImageButton
                android:id="@+id/icon1"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ch_mandarin"
                android:background="@color/transparent" />

            <ImageButton
                android:id="@+id/icon2"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:src="@drawable/ch_pineapple" />

            <ImageButton
                android:id="@+id/icon3"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ch_grape"
                android:background="@color/transparent" />

            <ImageButton
                android:id="@+id/icon4"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ch_strawberry"
                android:background="@color/transparent" />

            <ImageButton
                android:id="@+id/icon5"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ch_apple"
                android:background="@color/transparent" />

            <ImageButton
                android:id="@+id/icon6"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ch_mango"
                android:background="@color/transparent" />

            <ImageButton
                android:id="@+id/icon7"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ch_kiwi"
                android:background="@color/transparent" />

            <ImageButton
                android:id="@+id/icon8"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ch_cherry"
                android:background="@color/transparent" />
        </GridLayout>

        <Button
            android:id="@+id/okBtn1"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/rounded_button"
            android:text="만들기"
            android:textSize="20dp"
            android:textColor="@color/white"
            android:fontFamily="@font/pretendardsemibold"
            android:layout_marginTop="90dp" />


    </LinearLayout>

</LinearLayout>