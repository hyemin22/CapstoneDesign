<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".fragment.AlarmSettingFragment"
    android:orientation="vertical">
    <!-- TODO: Update blank fragment layout -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#00ff0000"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="20dp"
            app:srcCompat="@drawable/backbtn"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="5dp"
            android:gravity="center"
            android:fontFamily="@font/pretendardsemibold"
            android:text="알림"
            android:textSize="18dp" />
        <Space
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:layout_weight="0" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <Switch
            android:id="@+id/switch1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:track="@drawable/switch_track_selector"
            android:thumb="@drawable/switch_thumb"
            android:layout_weight="1"
            android:textSize="17dp"
            android:fontFamily="@font/pretendardsemibold"
            android:text="전체 알림" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="7dp"
        android:layout_marginTop="10dp"
        android:background="#EFEFEF"
        android:layout_gravity="center"/>

    <Switch
        android:id="@+id/switch2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:track="@drawable/switch_track_selector"
        android:thumb="@drawable/switch_thumb"
        android:textSize="15dp"
        android:fontFamily="@font/pretendardsemibold"
        android:text="하루미션 알림" />

    <Switch
        android:id="@+id/switch3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:track="@drawable/switch_track_selector"
        android:thumb="@drawable/switch_thumb"
        android:textSize="15dp"
        android:fontFamily="@font/pretendardsemibold"
        android:text="추억일기 알림" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:gravity="center"
        android:textColor="#B4B4B4"
        android:fontFamily="@font/pretendardmedium"
        android:text="일기 등록 / 수정 / 삭제 알림"
        android:textSize="13dp" />

    <Switch
        android:id="@+id/switch4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:track="@drawable/switch_track_selector"
        android:thumb="@drawable/switch_thumb"
        android:textSize="15dp"
        android:fontFamily="@font/pretendardsemibold"
        android:text="방명록 업로드 시 알림" />

    <Switch
        android:id="@+id/switch5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:track="@drawable/switch_track_selector"
        android:thumb="@drawable/switch_thumb"
        android:textSize="15dp"
        android:fontFamily="@font/pretendardsemibold"
        android:text="알림 및 쪽지" />

    <Switch
        android:id="@+id/switch6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:track="@drawable/switch_track_selector"
        android:thumb="@drawable/switch_thumb"
        android:textSize="15dp"
        android:fontFamily="@font/pretendardsemibold"
        android:text="위시리스트 등록 시 알림" />

<!--    <Switch-->
<!--        android:id="@+id/switch7"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:gravity="center_vertical"-->
<!--        android:layout_marginTop="15dp"-->
<!--        android:layout_marginLeft="20dp"-->
<!--        android:layout_marginRight="20dp"-->
<!--        android:track="@drawable/switch_track_selector"-->
<!--        android:thumb="@drawable/switch_thumb"-->
<!--        android:textSize="15dp"-->
<!--        android:fontFamily="@font/pretendardsemibold"-->
<!--        android:text="가족 공동 스크랩 시 알림" />-->

    <Switch
        android:id="@+id/switch8"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="15dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:track="@drawable/switch_track_selector"
        android:thumb="@drawable/switch_thumb"
        android:textSize="15dp"
        android:fontFamily="@font/pretendardsemibold"
        android:text="마케팅 알림 수신 동의" />


</LinearLayout>