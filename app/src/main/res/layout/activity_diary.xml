<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:id="@+id/toplayout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_alignParentTop="true">

                <ImageView
                    android:id="@+id/backBtn"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/pretendardregular"
                    android:gravity="center"
                    android:src="@drawable/backbtn" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/albumname"
                        android:fontFamily="@font/pretendardbold"
                        android:text="앨범 · "
                        android:textColor="@color/black"
                        android:textSize="20dp" />

                    <TextView
                        android:id="@+id/albumname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/pretendardbold"
                        android:text="2023 제주여행"
                        android:textColor="@color/black"
                        android:textSize="20dp" />
                </LinearLayout>

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="7dp"
                android:layout_gravity="center"
                android:background="#EFEFEF" />

            <LinearLayout
                android:id="@+id/backgroundOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/profile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="10dp"
                        android:layout_marginBottom="10dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ch_mango" />

                    <TextView
                        android:id="@+id/nickname"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_toRightOf="@id/profile"
                        android:fontFamily="@font/pretendardsemibold"
                        android:maxLines="1"
                        android:text="하연"
                        android:textColor="@color/black"
                        android:textSize="17dp" />

                    <TextView
                        android:id="@+id/date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/nickname"
                        android:layout_marginTop="4dp"
                        android:layout_toRightOf="@id/profile"
                        android:fontFamily="@font/pretendardmedium"
                        android:text="2024.11.20(수)"
                        android:textColor="@color/gray"
                        android:textSize="13dp" />

                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_placepickergray" />

                    <TextView
                        android:id="@+id/place"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendardregular"
                        android:hint="제주 협재해수욕장"
                        android:textSize="15dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="협재바다에서 피크닉 🧺"
                    android:textColor="@color/black"
                    android:textSize="28dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <HorizontalScrollView
                        android:layout_width="wrap_content"
                        android:layout_height="250dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card1"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img1"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card2"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img2"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card3"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img3"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card4"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img4"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card5"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img5"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card6"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img6"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card7"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img7"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card8"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img8"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card9"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img9"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card10"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img10"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/pretendardregular"
                        android:text="드디어 미루고 미루던 제주 피크닉을 했습니다!\n날씨가 안좋아서 걱정했는데 다행히 저녁 즈음 되니까 싹 개서 다행이었다 ㅎㅎ "
                        android:textColor="@color/black"
                        android:textSize="18dp" />


                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp">

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="30dp"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/linearLayout"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/likeSelect"
                                    android:layout_width="60dp"
                                    android:layout_height="40dp"
                                    android:layout_marginTop="30dp"
                                    android:background="@drawable/ic_emojiselect"
                                    android:visibility="visible" />

                            </LinearLayout>

                        </HorizontalScrollView>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/likeCardView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="invisible"
                            app:cardCornerRadius="15dp"
                            app:cardElevation="2dp"
                            app:cardUseCompatPadding="true">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingStart="5dp"
                                android:paddingEnd="5dp">

                                <Button
                                    android:id="@+id/like1"
                                    android:layout_width="45dp"
                                    android:layout_height="45dp"
                                    android:layout_margin="5dp"
                                    android:background="@drawable/ic_like1" />

                                <Button
                                    android:id="@+id/like2"
                                    android:layout_width="45dp"
                                    android:layout_height="45dp"
                                    android:layout_margin="5dp"
                                    android:background="@drawable/ic_like2" />

                                <Button
                                    android:id="@+id/like3"
                                    android:layout_width="45dp"
                                    android:layout_height="45dp"
                                    android:layout_margin="5dp"
                                    android:background="@drawable/ic_like3" />

                                <Button
                                    android:id="@+id/like4"
                                    android:layout_width="45dp"
                                    android:layout_height="45dp"
                                    android:layout_margin="5dp"
                                    android:background="@drawable/ic_like4" />

                                <Button
                                    android:id="@+id/like5"
                                    android:layout_width="45dp"
                                    android:layout_height="45dp"
                                    android:layout_margin="5dp"
                                    android:background="@drawable/ic_like5" />

                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
