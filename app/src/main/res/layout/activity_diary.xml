<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:id="@+id/toplayout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_alignParentTop="true">

                <ImageView
                    android:id="@+id/backBtn"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/pretendardregular"
                    android:gravity="center"
                    android:src="@drawable/backbtn"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true" >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toStartOf="@id/albumname"
                    android:layout_centerVertical="true"
                    android:text="앨범 · "
                    android:fontFamily="@font/pretendardbold"
                    android:textColor="@color/black"
                    android:textSize="20dp" />

                <TextView
                    android:id="@+id/albumname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/pretendardbold"
                    android:text="2023 제주여행"
                    android:textColor="@color/black"
                    android:textSize="20dp" />
            </LinearLayout>

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="7dp"
                android:layout_gravity="center"
                android:background="#EFEFEF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" >

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/profile"
                        android:layout_width="60dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:layout_marginBottom="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ch_mango" />

                    <TextView
                        android:id="@+id/nickname"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_toRightOf="@id/profile"
                        android:layout_marginTop="20dp"
                        android:maxLines="1"
                        android:text="하연"
                        android:textColor="@color/black"
                        android:textSize="17dp"
                        android:fontFamily="@font/pretendardsemibold" />

                    <TextView
                        android:id="@+id/date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toRightOf="@id/profile"
                        android:layout_below="@id/nickname"
                        android:layout_marginTop="4dp"
                        android:text="2024.11.20(수)"
                        android:textSize="13dp"
                        android:textColor="@color/gray"
                        android:fontFamily="@font/pretendardmedium" />

                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_placepickergray" />

                    <TextView
                        android:id="@+id/place"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ems="10"
                        android:fontFamily="@font/pretendardregular"
                        android:hint="제주 협재해수욕장"
                        android:textSize="15dp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pretendardsemibold"
                    android:layout_marginBottom="10dp"
                    android:text="협재바다에서 피크닉 🧺"
                    android:textColor="@color/black"
                    android:textSize="28dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <HorizontalScrollView
                        android:layout_width="wrap_content"
                        android:layout_height="250dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:orientation="horizontal">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card1"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img1"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/diaryimg1" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card2"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img2"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/diaryimg2" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card3"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img3"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card4"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img4"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                            <androidx.cardview.widget.CardView
                                android:id="@+id/card5"
                                android:layout_width="210dp"
                                android:layout_height="250dp"
                                android:layout_marginEnd="5dp"
                                android:scaleType="centerCrop"
                                app:cardCornerRadius="8dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:id="@+id/img5"
                                    android:layout_width="210dp"
                                    android:layout_height="250dp"
                                    android:layout_marginEnd="5dp"
                                    android:scaleType="centerCrop" />
                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:orientation="vertical">

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="@font/pretendardregular"
                            android:text="드디어 미루고 미루던 제주 피크닉을 했습니다!\n날씨가 안좋아서 걱정했는데 다행히 저녁 즈음 되니까 싹 개서 다행이었다 ㅎㅎ "
                            android:textColor="@color/black"
                            android:textSize="18dp" />

                    </ScrollView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>
