<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginBottom="70dp"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 첫 번째 LinearLayout (상단 부분) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/monthText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_marginLeft="20dp"
                    android:textSize="26dp"
                    android:text="날짜"
                    android:textColor="@color/black"
                    android:layout_weight="1"
                    android:fontFamily="@font/pretendardsemibold" />

                <ImageButton
                    android:id="@+id/dateSpinnerBtn"
                    android:layout_width="33dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginTop="5dp"
                    android:layout_marginRight="25dp"
                    android:backgroundTint="@color/transparent"
                    android:rotation="270"
                    android:scaleType="fitXY"
                    android:src="@drawable/ic_chevron" />

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_gravity="center">

                    <Spinner
                        android:id="@+id/spinner"
                        android:layout_width="80dp"
                        android:layout_height="33dp"
                        android:layout_gravity="bottom"
                        android:layout_marginRight="18dp"
                        android:fontFamily="@font/pretendardextrabold"
                        android:background="@drawable/spinner_bg"
                        android:entries="@array/selectCalender" />

                    <ImageView
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginRight="28dp"
                        android:layout_gravity="end|center_vertical"
                        android:src="@drawable/spinnerdropdown" />

                </FrameLayout>

            </LinearLayout>

            <!-- 요일 텍스트 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:padding="5dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/sundayText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="일"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:fontFamily="@font/pretendardbold"
                    android:textSize="18dp"/>
                <TextView
                    android:id="@+id/mondayText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="월"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:fontFamily="@font/pretendardbold"
                    android:textSize="18dp"/>
                <TextView
                    android:id="@+id/tuesdayText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="화"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:fontFamily="@font/pretendardbold"
                    android:textSize="18dp"/>
                <TextView
                    android:id="@+id/wednesdayText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="수"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:fontFamily="@font/pretendardbold"
                    android:textSize="18dp"/>
                <TextView
                    android:id="@+id/thursdayText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="목"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:fontFamily="@font/pretendardbold"
                    android:textSize="18dp"/>
                <TextView
                    android:id="@+id/fridayText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="금"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:fontFamily="@font/pretendardbold"
                    android:textSize="18dp"/>
                <TextView
                    android:id="@+id/saturdayText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="토"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:fontFamily="@font/pretendardbold"
                    android:textSize="18dp"/>

            </LinearLayout>

            <!-- 첫 번째 RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1" />

            <!-- Divider View -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="7dp"
                    android:layout_marginTop="20dp"
                    android:background="#EFEFEF"
                    android:layout_gravity="center"/>
            </LinearLayout>

            <!-- 두 번째 RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerview2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
