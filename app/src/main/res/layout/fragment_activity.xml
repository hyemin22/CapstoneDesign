<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginBottom="70dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="30dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="47dp"
            android:background="@drawable/more_rounded_textbox"/>

        <ImageView
            android:layout_width="25dp"
            android:layout_height="47dp"
            android:layout_marginLeft="15dp"
            android:src="@drawable/ic_placepicker" />

        <TextView
            android:id="@+id/spinner1"
            style="@style/Widget.AppCompat.Spinner"
            android:layout_width="170dp"
            android:layout_height="47dp"
            android:hint="서울"
            android:textSize="17dp"
            android:textColor="@color/black"
            android:fontFamily="@font/pretendardmedium"
            android:layout_marginLeft="30dp"
            android:paddingStart="15dp"
            android:dropDownWidth="match_parent"
            android:popupBackground="@drawable/rounded_background"
            android:spinnerMode="dropdown" />

        <TextView
            android:id="@+id/spinner2"
            style="@style/Widget.AppCompat.Spinner"
            android:layout_width="170dp"
            android:layout_height="47dp"
            android:layout_toRightOf="@id/spinner1"
            android:hint="강남구"
            android:textSize="17dp"
            android:textColor="@color/black"
            android:fontFamily="@font/pretendardmedium"
            android:paddingStart="15dp"
            android:dropDownWidth="match_parent"
            android:popupBackground="@drawable/rounded_background"
            android:spinnerMode="dropdown" />

        <TextView
            android:id="@+id/ment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/spinner1"
            android:layout_marginTop="30dp"
            android:layout_marginStart="5dp"
            android:layout_marginBottom="-5dp"
            android:text="가족끼리 먹기 좋은\n근처 맛집"
            android:textSize="26dp"
            android:fontFamily="@font/pretendardsemibold"
            android:textColor="@color/black"/>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/ment"
            android:layout_marginTop="30dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/activityView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </RelativeLayout>
    </RelativeLayout>
</ScrollView>